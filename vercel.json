{
  "version": 2,
  "buildCommand": "cd frontend && npm run build",
  "builds": [
    {
      "src": "frontend/build/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node",
      "config": { "includeFiles": "api/**" }
    }
  ],
  "routes": [
    {
      "src": "^/api/(.*)$",
      "dest": "/api/$1.js"
    },
    {
      "src": "^/static/(.*)$",
      "dest": "/frontend/build/static/$1"
    },
    {
      "src": "^/asset-manifest.json$",
      "dest": "/frontend/build/asset-manifest.json"
    },
    {
      "src": "^/manifest.json$",
      "dest": "/frontend/build/manifest.json"
    },
    {
      "src": "^/favicon.ico$",
      "dest": "/frontend/build/favicon.ico"
    },
    {
      "src": "^/logo192.png$",
      "dest": "/frontend/build/logo192.png"
    },
    {
      "src": "^/logo512.png$",
      "dest": "/frontend/build/logo512.png"
    },
    {
      "src": "^/robots.txt$",
      "dest": "/frontend/build/robots.txt"
    },
    {
      "src": "^/(.*)$",
      "dest": "/frontend/build/index.html"
    }
  ],
  "env": {
    "REACT_APP_API_URL": "https://$VERCEL_URL/api",
    "JWT_SECRET": "agranova_secret_key_2026"
  }
}
