# Server Configuration
PORT=${PORT:-5001}
NODE_ENV=${NODE_ENV:-production}

# Database - Using MongoDB Atlas for production
MONGODB_URI=${MONGODB_URI:-mongodb://localhost:27017/agranova}

# JWT Secret
JWT_SECRET=${JWT_SECRET:-agranova_secret_key_2026_change_in_production}

# OpenAI API (for AI Assistant)
OPENAI_API_KEY=${OPENAI_API_KEY:-your_openai_api_key_here}

# Frontend URL (for CORS)
FRONTEND_URL=${FRONTEND_URL:-https://agronova-smart-irrigation-system.vercel.app}
